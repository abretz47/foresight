# Android screenshot configuration for `fastlane screengrab` (standalone use).
# When running `bundle exec fastlane android screenshots` the Fastfile lane
# passes these same paths directly to capture_android_screenshots, so the
# values below only take effect when screengrab is invoked outside of a lane.

# Locales for Android screenshots
locales(['en-US'])

# Remove previously generated screenshots
clear_previous_screenshots(true)

# Output directory for screenshots
output_directory("./fastlane/screenshots/android")

# Android app APK path (generated by EAS / Gradle)
app_apk_path("android/app/build/outputs/apk/release/app-release.apk")
tests_apk_path("android/app/build/outputs/apk/androidTest/release/app-release-androidTest.apk")

# Use the instrumentation test runner
use_tests_in_classes(["com.abretz.foresight.ScreenshotTest"])
