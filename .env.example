# Supabase configuration for cloud auth and data storage.
# Copy this file to .env and fill in the values from your Supabase project settings
# (Settings → API → Project URL and Project API keys → anon/public).
#
# Leave these blank (or omit the .env file entirely) to use local-only mode.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
