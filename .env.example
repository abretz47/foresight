# Foresight – environment variable reference
#
# Copy this file to .env.local (git-ignored) and set the values you need.
# Never commit secrets or .env.local.
#
# Expo only exposes variables prefixed with EXPO_PUBLIC_ to the app bundle.
# All others are server-side / build-time only.

# ── Feature flags ──────────────────────────────────────────────────────────
#
# Set to "true" to enable the PiTrac launch-monitor WebSocket integration.
# Leave unset (or set to anything other than "true") to keep the feature
# hidden in production builds.
#
# EXPO_PUBLIC_ENABLE_PITRAC=true

# ── Supabase (optional cloud sync) ────────────────────────────────────────
#
# EXPO_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
